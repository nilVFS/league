*.log
*.tmp
*.swp
*.swo

# Editors
.vscode/
.idea/

# Coverage
coverage/
htmlcov/
.coverage

# OS
.DS_Store
Thumbs.db

# Build directories
dist/
build/
target/
.gradle/

# Cache
.mypy_cache/
.pytest_cache/
.julia/
zig-cache/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```